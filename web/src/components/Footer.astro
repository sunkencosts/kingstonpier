---
interface Props {
  secs: number;
}
const { secs } = Astro.props;
---

<footer class="ft">
  
  <span>Refreshes ~every minute · updated <span id="secs-ago-foot">{secs}</span>s ago</span>
</footer>

<style>
  .ft {
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
    gap: 8px 18px;
    align-items: center;
    padding: 2px 4px 4px;
    font-size: 12px;
    color: var(--muted);
  }
</style>
