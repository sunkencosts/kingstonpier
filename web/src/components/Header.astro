---
interface Props {
  secs: number;
}
const { secs } = Astro.props;
---

<header class="hdr">
  <div class="brand">
    <div class="logo" aria-hidden="true">
      <svg width="22" height="18" viewBox="0 0 640 512" fill="#3a2500">
        <path d="M189.61 310.58c3.54 3.26 15.27 9.42 34.39 9.42s30.86-6.16 34.39-9.42c16.02-14.77 34.5-22.58 53.46-22.58h16.3c18.96 0 37.45 7.81 53.46 22.58 3.54 3.26 15.27 9.42 34.39 9.42s30.86-6.16 34.39-9.42c14.86-13.71 31.88-21.12 49.39-22.16l-112.84-80.6 18-12.86c3.64-2.58 8.28-3.52 12.62-2.61l100.35 21.53c25.91 5.53 51.44-10.97 57-36.88 5.55-25.92-10.95-51.44-36.88-57L437.68 98.47c-30.73-6.58-63.02.12-88.56 18.38l-80.02 57.17c-10.38 7.39-19.36 16.44-26.72 26.94L173.75 299c5.47 3.23 10.82 6.93 15.86 11.58zM624 352h-16c-26.04 0-45.8-8.42-56.09-17.9-8.9-8.21-19.66-14.1-31.77-14.1h-16.3c-12.11 0-22.87 5.89-31.77 14.1C461.8 343.58 442.04 352 416 352s-45.8-8.42-56.09-17.9c-8.9-8.21-19.66-14.1-31.77-14.1h-16.3c-12.11 0-22.87 5.89-31.77 14.1C269.8 343.58 250.04 352 224 352s-45.8-8.42-56.09-17.9c-8.9-8.21-19.66-14.1-31.77-14.1h-16.3c-12.11 0-22.87 5.89-31.77 14.1C77.8 343.58 58.04 352 32 352H16c-8.84 0-16 7.16-16 16v32c0 8.84 7.16 16 16 16h16c38.62 0 72.72-12.19 96-31.84 23.28 19.66 57.38 31.84 96 31.84s72.72-12.19 96-31.84c23.28 19.66 57.38 31.84 96 31.84s72.72-12.19 96-31.84c23.28 19.66 57.38 31.84 96 31.84h16c8.84 0 16-7.16 16-16v-32c0-8.84-7.16-16-16-16zm-512-96c44.18 0 80-35.82 80-80s-35.82-80-80-80-80 35.82-80 80 35.82 80 80 80z"></path>
      </svg>
    </div>
    <div class="wordmark">
      <span class="name">Kingston&nbsp;Pier</span>
      <a
        class="sub"
        href="https://www.google.com/maps/place/Gord+Downie+Memorial+Pier/@44.220924,-76.5017481,457m/data=!3m1!1e3!4m6!3m5!1s0x4cd2abbcae9992ab:0xc3aab9836ba87412!8m2!3d44.2206313!4d-76.5018545!16s%2Fg%2F11hz5vj3st?entry=ttu&g_ep=EgoyMDI2MDcwNy4wIKXMDSoASAFQAw%3D%3D"
        target="_blank"
        rel="noopener noreferrer"
      >
        <svg class="pin" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0z"></path>
          <circle cx="12" cy="10" r="3"></circle>
        </svg>
        <span>Breakwater Park · Kingston, ON</span>
      </a>
    </div>
  </div>

  <div class="hdr-right">
    <!-- Live -->
    <div class="pill status status-live" role="status">
      <span class="dot-wrap">
        <span class="dot"></span>
        <span class="dot live-ping"></span>
      </span>
      <span class="status-txt">Live · updated <span id="secs-ago">{secs}</span>s ago</span>
    </div>
    <!-- Stale (shown when [data-feed="stale"]) -->
    <div class="pill status status-stale" role="status">
      <span class="dot-stale"></span>
      <span class="status-txt">Feed unavailable · <span id="stale-ago">last seen 6m ago</span></span>
    </div>

    <button id="theme-toggle" class="pill theme-btn" type="button" aria-label="Toggle dark mode" title="Toggle theme">
      <svg class="ico-sun" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round">
        <circle cx="12" cy="12" r="4.2"></circle>
        <path d="M12 2.5v2.4M12 19.1v2.4M4.6 4.6l1.7 1.7M17.7 17.7l1.7 1.7M2.5 12h2.4M19.1 12h2.4M4.6 19.4l1.7-1.7M17.7 6.3l1.7-1.7"></path>
      </svg>
      <svg class="ico-moon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round">
        <path d="M21 12.8A9 9 0 1 1 11.2 3a7 7 0 0 0 9.8 9.8z"></path>
      </svg>
    </button>
  </div>
</header>

<style>
  .hdr {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 12px;
    flex-wrap: wrap;
  }
  .brand {
    display: flex;
    align-items: center;
    gap: 11px;
  }
  .logo {
    width: 36px;
    height: 36px;
    border-radius: 11px;
    background: var(--accent);
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 3px 8px -2px rgba(120, 80, 0, 0.35);
  }
  .wordmark {
    display: flex;
    flex-direction: column;
    line-height: 1.15;
  }
  .name {
    font-family: 'Space Grotesk', sans-serif;
    font-weight: 700;
    font-size: 17px;
    letter-spacing: -0.01em;
    color: var(--heading);
  }
  .sub {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    font-size: 11.5px;
    color: var(--muted);
    text-decoration: none;
    width: fit-content;
    transition: color 0.15s ease;
  }
  .sub:hover {
    color: var(--text);
  }
  .pin {
    flex: none;
  }

  .hdr-right {
    display: flex;
    align-items: center;
    gap: 8px;
  }
  .pill {
    display: flex;
    align-items: center;
    gap: 9px;
    padding: 8px 13px;
    border-radius: 999px;
    background: var(--card);
    border: 1px solid var(--border);
    font-size: 12px;
    font-weight: 600;
    color: var(--text);
  }
  .status-txt {
    white-space: nowrap;
  }

  .dot-wrap {
    position: relative;
    width: 8px;
    height: 8px;
    display: inline-block;
  }
  .dot,
  .live-ping {
    position: absolute;
    inset: 0;
    border-radius: 50%;
    background: #33a88b;
  }
  .live-ping {
    animation: pierPulse 2.4s ease-out infinite;
  }

  .status-stale {
    background: color-mix(in srgb, #de5240 15%, var(--card));
    border-color: color-mix(in srgb, #de5240 40%, transparent);
  }
  .dot-stale {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: #de5240;
  }

  /* Toggle which status pill is visible based on the feed state. */
  :global([data-feed='stale']) .status-live {
    display: none;
  }
  :global(:not([data-feed='stale'])) .status-stale {
    display: none;
  }

  .theme-btn {
    cursor: pointer;
    color: var(--muted);
    padding: 8px;
  }
  .theme-btn:hover {
    color: var(--text);
  }
  .ico-moon {
    display: none;
  }
  :global([data-theme='dark']) .ico-sun {
    display: none;
  }
  :global([data-theme='dark']) .ico-moon {
    display: inline;
  }

  /* On narrow screens the header stacks; let the status/toggle row fill the
     width so the theme button pushes out to the far right. */
  @media (max-width: 480px) {
    .hdr-right {
      width: 100%;
      justify-content: space-between;
    }
  }
</style>
