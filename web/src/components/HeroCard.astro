---
import { LEVELS, LEVEL_COLORS } from '../lib/busyness';

interface Props {
  total: number;
  lo: number;
  hi: number;
  levelIdx: number;
  timestamp: string; // e.g. "Thu · 3:07 PM"
  comparePct: number; // signed
  compareSub: string;
}
const { total, lo, hi, levelIdx, timestamp, comparePct, compareSub } = Astro.props;

const levelWord = LEVELS[levelIdx];
const levelColor = LEVEL_COLORS[levelIdx];

const busier = comparePct >= 0;
const compareText = busier ? 'Busier than usual' : 'Quieter than usual';
// Warm accent for "busier", cool teal for "quieter".
const compareColor = busier ? '#D9772E' : '#2E9E86';
const compareBg = busier
  ? 'color-mix(in srgb, #E8863C 16%, var(--card))'
  : 'color-mix(in srgb, #2E9E86 15%, var(--card))';

// Precompute the tide gauge here — Astro's template parser dislikes bare "<="
// comparisons inside inline expressions.
const segs = LEVEL_COLORS.map((c, i) => {
  const filled = i <= levelIdx;
  const current = i === levelIdx;
  const style = [
    `background:${filled ? c : 'var(--card-2)'}`,
    `border:1px solid ${filled ? c : 'var(--border)'}`,
    current ? `box-shadow:0 0 0 3px color-mix(in srgb, ${c} 32%, transparent)` : '',
  ]
    .filter(Boolean)
    .join(';');
  return { i, style };
});
const labs = LEVELS.map((l, i) => ({
  l,
  style: i === levelIdx ? `font-weight:700;color:${LEVEL_COLORS[i]}` : 'font-weight:500;color:var(--muted)',
}));
---

<section class="card hero">
  <div class="hero-top">
    <span class="eyebrow">Right now on the pier</span>
    <span class="ts" id="hero-ts">{timestamp}</span>
  </div>

  <div class="hero-main">
    <div class="count-col">
      <span class="count-line">
        <span class="approx">≈</span>
        <span class="count" id="hero-total">{total}</span>
      </span>
      <span class="count-cap">people on the pier - give or take a few</span>

    </div>

    <div class="level-col">
      <span class="level-word" id="hero-word" style={`color:${levelColor}`}>{levelWord}</span>
      <span class="compare" id="hero-compare" style={`background:${compareBg};color:${compareColor}`}>
        <svg id="hero-compare-chev" class="chev" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3.2" stroke-linecap="round" stroke-linejoin="round" style={busier ? '' : 'transform:rotate(180deg)'}>
          <path d="M6 15l6-6 6 6"></path>
        </svg>
        <span id="hero-compare-text">{compareText}</span>
      </span>
    </div>
  </div>

  <div class="compare-sub" id="hero-sub">{compareSub}</div>

  <!-- Tide gauge: segments 0..idx filled with their level color, current segment glows. -->
  <div class="tide" id="tide">
    <div class="tide-segs">
      {segs.map((s) => <div class="tide-seg" data-i={s.i} style={s.style} />)}
    </div>
    <div class="tide-labels">
      {labs.map((s, i) => <span class="tide-label" data-i={i} style={s.style}>{s.l}</span>)}
    </div>
  </div>

  <div class="stale-note" id="stale-note">
    Showing the last known reading. Live counts resume when the feed reconnects.
  </div>
</section>

<style>
  .hero {
    position: relative;
    overflow: hidden;
    padding: clamp(18px, 2.6vw, 24px);
  }
  .hero-top {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 10px;
  }
  .ts {
    font-size: 12px;
    color: var(--muted);
  }
  .hero-main {
    display: flex;
    align-items: flex-end;
    gap: clamp(14px, 3vw, 26px);
    flex-wrap: wrap;
    margin-top: 12px;
  }
  .count-col {
    display: flex;
    flex-direction: column;
  }
  .count-line {
    display: flex;
    align-items: flex-start;
    gap: 6px;
    color: var(--heading);
  }
  .approx {
    font-family: 'Space Grotesk', sans-serif;
    font-weight: 500;
    font-size: clamp(26px, 5vw, 38px);
    line-height: 1;
    color: var(--muted);
    margin-top: clamp(6px, 1.4vw, 12px);
  }
  .count {
    font-family: 'Space Grotesk', sans-serif;
    font-weight: 700;
    font-size: clamp(60px, 12vw, 92px);
    line-height: 0.86;
    letter-spacing: -0.035em;
  }
  .count-cap {
    font-size: 13px;
    color: var(--muted);
    margin-top: 8px;
  }
  .range {
    display: inline-flex;
    align-self: flex-start;
    align-items: center;
    gap: 6px;
    margin-top: 9px;
    padding: 3px 10px;
    border-radius: 999px;
    background: var(--card-2);
    border: 1px solid var(--border);
    font-size: 11.5px;
    color: var(--muted);
  }

  .level-col {
    display: flex;
    flex-direction: column;
    gap: 10px;
    padding-bottom: 4px;
  }
  .level-word {
    font-family: 'Space Grotesk', sans-serif;
    font-weight: 700;
    text-transform: uppercase;
    font-size: clamp(28px, 5.4vw, 40px);
    line-height: 0.92;
    letter-spacing: -0.01em;
    transition: color 0.3s ease;
  }
  .compare {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    align-self: flex-start;
    padding: 5px 12px;
    border-radius: 999px;
    font-size: 12.5px;
    font-weight: 600;
  }

  .compare-sub {
    margin-top: 9px;
    font-size: 12.5px;
    color: var(--muted);
  }

  .tide {
    margin-top: 20px;
  }
  .tide-segs {
    display: flex;
    gap: 5px;
  }
  .tide-seg {
    flex: 1;
    height: 13px;
    border-radius: 7px;
    transition: all 0.3s ease;
  }
  .tide-labels {
    display: flex;
    gap: 5px;
    margin-top: 8px;
  }
  .tide-label {
    flex: 1;
    text-align: center;
    font-size: 10.5px;
    transition: color 0.3s ease;
  }

  /* Amber "last known reading" note — only in the stale feed state. */
  .stale-note {
    display: none;
    margin-top: 16px;
    padding: 10px 13px;
    border-radius: 12px;
    background: color-mix(in srgb, #e7b23c 15%, var(--card));
    border: 1px solid color-mix(in srgb, #e7b23c 42%, transparent);
    font-size: 12.5px;
    color: var(--text);
  }
  :global([data-feed='stale']) .stale-note {
    display: block;
  }
</style>
