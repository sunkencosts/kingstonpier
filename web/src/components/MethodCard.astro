---
// A quiet "under the hood" card: how the count above is actually produced and
// kept honest. The facts here mirror the real pipeline (tracker/README.md) —
// density model, point labels, held-out error, night gating — so it reads as
// someone who knows the model, not marketing copy.

// A small deterministic "density map": two soft blobs of people over the sand.
// Purely decorative, but it makes the core idea — a heat-map that *sums* to the
// count — legible at a glance. Cell opacity ∝ predicted density.
const COLS = 16;
const ROWS = 6;
const blobs = [
  { x: 4.5, y: 3.2, s: 2.6, w: 1.0 },
  { x: 11.5, y: 2.4, s: 3.4, w: 0.8 },
];
const cells = Array.from({ length: ROWS * COLS }, (_, k) => {
  const cx = k % COLS;
  const cy = Math.floor(k / COLS);
  let v = 0;
  for (const b of blobs) {
    const d2 = ((cx - b.x) ** 2 + (cy - b.y) ** 2) / (2 * b.s * b.s);
    v += b.w * Math.exp(-d2);
  }
  // Bias a little toward the near shoreline (bottom rows) and clamp.
  v = Math.min(1, v * (0.7 + 0.3 * (cy / (ROWS - 1))));
  const opacity = (0.06 + 0.9 * v).toFixed(3);
  return { opacity };
});
---

<section class="card method">
  <div class="m-head">
    <span class="eyebrow">Under the hood</span>
    <h2 class="m-title">How the count is made</h2>
    <p class="m-lede">
      No one is watching a screen. A small computer-vision model on a Raspberry Pi
      reads the public pier webcams and turns each frame into the number above.
    </p>
  </div>

  <!-- Pipeline: sample → count → keep. Stacks on narrow screens. -->
  <ol class="pipe">
    <li class="step">
      <div class="step-ico">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M3 8.5A2 2 0 0 1 5 6.5h9.5a2 2 0 0 1 2 2v1.6l3-2v8.8l-3-2v1.6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path>
        </svg>
      </div>
      <div class="step-txt">
        <span class="step-name">Sample</span>
        <p>Five <a class="pier-link" href="https://www.cityofkingston.ca/news-and-notices/webcams/" target="_blank" rel="noopener">City of Kingston pier cameras</a>, one 640×360 frame each, pulled about every three minutes.</p>
      </div>
    </li>

    <li class="step">
      <div class="step-ico">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <rect x="3" y="3" width="18" height="18" rx="2.5"></rect>
          <path d="M9 3v18M15 3v18M3 9h18M3 15h18"></path>
        </svg>
      </div>
      <div class="step-txt">
        <span class="step-name">Count</span>
        <p>A <em>density model</em> predicts a heat-map of where people are, then sums it to a headcount.</p>
        <div class="densmap" aria-hidden="true">
          <div class="dens-grid" style={`grid-template-columns:repeat(${COLS},1fr)`}>
            {cells.map((c) => <span class="dens-cell" style={`opacity:${c.opacity}`} />)}
          </div>
          <span class="dens-cap">predicted density &nbsp;→&nbsp; Σ = count</span>
        </div>
      </div>
    </li>

    <li class="step">
      <div class="step-ico">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <ellipse cx="12" cy="5.5" rx="7.5" ry="2.8"></ellipse>
          <path d="M4.5 5.5v6c0 1.5 3.4 2.8 7.5 2.8s7.5-1.3 7.5-2.8v-6M4.5 11.5v6c0 1.5 3.4 2.8 7.5 2.8s7.5-1.3 7.5-2.8v-6"></path>
        </svg>
      </div>
      <div class="step-txt">
        <span class="step-name">Keep</span>
        <p>Only the integer total lands in the database and reaches this page. <strong>No frames are ever stored.</strong></p>
      </div>
    </li>
  </ol>


  <!-- Honesty about the limits is itself the credential. -->
  <p class="caveat">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <circle cx="12" cy="12" r="9"></circle><path d="M12 8v5"></path><path d="M12 16.5h.01"></path>
    </svg>
    <span>
      The five views overlap, so someone can be counted twice and sometimes geese are counted! Read the number as
      a strong <em>relative</em> gauge, not a turnstile. And after dark the infrared
      frames go near-black, so it records nothing rather than guessing.
    </span>
  </p>
</section>

<style>
  .method {
    grid-column: 1 / -1;
    padding: clamp(18px, 2.6vw, 26px);
    display: flex;
    flex-direction: column;
    gap: clamp(18px, 2.4vw, 24px);
  }

  .m-title {
    font-family: 'Space Grotesk', sans-serif;
    font-weight: 700;
    font-size: clamp(20px, 3.4vw, 26px);
    letter-spacing: -0.02em;
    color: var(--heading);
    margin: 8px 0 0;
  }
  .m-lede {
    margin: 8px 0 0;
    max-width: 62ch;
    font-size: 14px;
    line-height: 1.55;
    color: var(--muted);
  }

  /* Pipeline ─────────────────────────────────────────────── */
  .pipe {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: clamp(12px, 2vw, 20px);
  }
  .step {
    display: flex;
    gap: 12px;
    padding: 14px;
    border-radius: 14px;
    background: var(--card-2);
    border: 1px solid var(--border);
    position: relative;
  }
  /* Connecting arrow between steps (horizontal layout only). */
  .step:not(:last-child)::after {
    content: '';
    position: absolute;
    right: calc(clamp(12px, 2vw, 20px) / -2 - 5px);
    top: 50%;
    width: 9px;
    height: 9px;
    border-top: 2px solid var(--border);
    border-right: 2px solid var(--border);
    transform: translateY(-50%) rotate(45deg);
  }
  .step-ico {
    flex: none;
    width: 34px;
    height: 34px;
    display: grid;
    place-items: center;
    border-radius: 10px;
    background: color-mix(in srgb, var(--accent) 15%, var(--card));
    color: var(--accent);
  }
  .step-ico svg {
    width: 19px;
    height: 19px;
  }
  .step-name {
    font-family: 'Space Grotesk', sans-serif;
    font-weight: 600;
    font-size: 12px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--heading);
  }
  .step-txt p {
    margin: 5px 0 0;
    font-size: 13px;
    line-height: 1.5;
    color: var(--text);
  }
  .step-txt em {
    font-style: normal;
    color: var(--accent);
    font-weight: 600;
  }
  .pier-link {
    color: inherit;
    text-decoration: underline;
  }
  .pier-link:hover {
    color: var(--accent);
  }

  /* Density-map mini viz ─────────────────────────────────── */
  .densmap {
    margin-top: 11px;
  }
  .dens-grid {
    display: grid;
    gap: 2px;
    padding: 5px;
    border-radius: 8px;
    background: color-mix(in srgb, var(--heading) 6%, var(--card));
  }
  .dens-cell {
    aspect-ratio: 1;
    border-radius: 2px;
    background: var(--accent);
  }
  .dens-cap {
    display: block;
    margin-top: 6px;
    font-family: 'Space Grotesk', sans-serif;
    font-size: 10.5px;
    letter-spacing: 0.04em;
    color: var(--muted);
  }

  /* The model paragraph + fact chips ─────────────────────── */
  .model {
    display: flex;
    flex-direction: column;
    gap: 16px;
    padding-top: 4px;
  }
  .model-line {
    margin: 0;
    max-width: 68ch;
    font-size: 14px;
    line-height: 1.62;
    color: var(--text);
  }
  .model-line strong {
    color: var(--heading);
    font-weight: 600;
  }
  .facts {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 12px;
  }
  .fact {
    display: flex;
    flex-direction: column;
    gap: 5px;
    padding: 13px 14px;
    border-radius: 12px;
    background: var(--card-2);
    border: 1px solid var(--border);
  }
  .fact-k {
    font-family: 'Space Grotesk', sans-serif;
    font-weight: 700;
    font-size: 19px;
    letter-spacing: -0.01em;
    color: var(--heading);
    display: flex;
    align-items: baseline;
    gap: 7px;
  }
  .fact-vs {
    font-size: 12px;
    font-weight: 500;
    color: var(--muted);
    letter-spacing: 0;
  }
  .fact-v {
    font-size: 12px;
    line-height: 1.45;
    color: var(--muted);
  }

  /* Caveat ───────────────────────────────────────────────── */
  .caveat {
    display: flex;
    gap: 10px;
    margin: 0;
    padding: 13px 15px;
    border-radius: 12px;
    background: color-mix(in srgb, var(--accent) 9%, var(--card));
    border: 1px solid color-mix(in srgb, var(--accent) 30%, transparent);
    font-size: 12.5px;
    line-height: 1.55;
    color: var(--text);
  }
  .caveat svg {
    flex: none;
    width: 17px;
    height: 17px;
    margin-top: 1px;
    color: var(--accent);
  }
  .caveat em {
    font-style: normal;
    font-weight: 600;
    color: var(--heading);
  }

  /* Responsive: stack the pipeline and facts on narrow screens. */
  @media (max-width: 720px) {
    .pipe,
    .facts {
      grid-template-columns: 1fr;
    }
    .step:not(:last-child)::after {
      right: 50%;
      top: auto;
      bottom: calc(clamp(12px, 2vw, 20px) / -2 - 5px);
      transform: translateX(50%) rotate(135deg);
    }
  }
</style>
