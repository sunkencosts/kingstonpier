# Copy to .env (git-ignored) and adjust as needed. All optional — the defaults
# match a local dev setup with a seeded DB.

# Path to the SQLite file the tracker writes and the API reads.
KP_DB_PATH=../db/data/readings.db

# Comma-separated CORS origins allowed to call the API.
KP_CORS_ORIGINS=https://kingstonpier.ca,https://www.kingstonpier.ca,http://localhost:4321

# Cache-Control max-age (seconds) per endpoint — Cloudflare caches on these.
KP_NOW_CACHE=60
KP_HISTORY_CACHE=60
KP_POPULAR_CACHE=3600
KP_WEATHER_CACHE=600

# "Popular times" trailing window; when a reading is considered stale.
KP_POPULAR_WEEKS=8
KP_STALE_AFTER_S=600
