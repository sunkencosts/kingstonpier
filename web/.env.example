# Copy to .env (git-ignored). Vite exposes PUBLIC_* vars to client code.

# Base URL of the API the dashboard polls.
PUBLIC_API_BASE=https://api.kingstonpier.ca

# Local dev against the FastAPI service in ../api:
# PUBLIC_API_BASE=http://localhost:8000

# Force the built-in synthetic mock instead of the live API (design work with
# no backend). Any value other than "true" (or unset) uses the live API.
# PUBLIC_USE_MOCK=true
