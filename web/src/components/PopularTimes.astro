---
import { DAYS, type Day } from '../lib/busyness';
import { renderBars, heightMaxOf } from '../lib/bars';

interface Props {
  popularByDay: Record<Day, number[]>;
  selectedDay: Day; // day shown on first paint
  todayDay: Day; // real weekday — its current hour gets the "now" ring + overlay
  nowHour: number;
  capacity: number; // count that reads as a full-height bar
  trend: number[]; // today's ACTUAL hourly counts (for the today overlay)
  caption: string;
}
const { popularByDay, selectedDay, todayDay, nowHour, capacity, trend, caption } = Astro.props;

const isToday = selectedDay === todayDay;
const heightMax = heightMaxOf(popularByDay, trend);
const initialBars = renderBars(
  popularByDay[selectedDay],
  isToday ? trend : null,
  isToday ? nowHour : null,
  capacity,
  heightMax,
);
const dataJson = JSON.stringify({ popularByDay, todayDay, nowHour, capacity, heightMax, trend });
---

<section class="card chart-card">
  <div class="pop-head">
    <span class="eyebrow">Popular times</span>
    <div class="chips" id="day-chips">
      {
        DAYS.map((d) => (
          <button
            class:list={['chip', { active: d === selectedDay }]}
            data-day={d}
            type="button"
            aria-pressed={d === selectedDay ? 'true' : 'false'}
          >
            {d}
          </button>
        ))
      }
    </div>
  </div>

  <div class="bars sk-live" id="pop-bars" set:html={initialBars} />

  <div class="ticks">
    <span>6a</span><span>Noon</span><span>6p</span><span>11p</span>
  </div>

  

  <!-- <div class="pop-caption" id="pop-caption">{caption}</div> -->

  <script type="application/json" id="pop-data" set:html={dataJson} />
</section>

<script>
  import { renderBars } from '../lib/bars';

  const chips = document.getElementById('day-chips');
  const bars = document.getElementById('pop-bars');

  // Read the data source fresh on every click so live polls (which rewrite
  // #pop-data) are picked up without re-binding.
  function popData() {
    try {
      return JSON.parse(document.getElementById('pop-data')?.textContent || '{}');
    } catch {
      return {};
    }
  }

  // Tap-to-reveal for touch devices (where :hover never fires). On hover-capable
  // devices we skip this entirely — :hover already shows exactly one tooltip, and
  // a sticky click-state would let a second one linger while hovering elsewhere.
  if (bars && window.matchMedia('(hover: none)').matches) {
    document.addEventListener('click', (e) => {
      const col = (e.target as HTMLElement).closest('.bar-col') as HTMLElement | null;
      const reopen = col && !col.classList.contains('show-tip') && bars.contains(col);
      for (const c of bars.querySelectorAll('.bar-col.show-tip')) c.classList.remove('show-tip');
      if (reopen) col!.classList.add('show-tip');
    });
  }

  if (chips && bars) {
    chips.addEventListener('click', (e) => {
      const btn = (e.target as HTMLElement).closest('button.chip') as HTMLButtonElement | null;
      if (!btn) return;
      // Mark that the user has made an explicit choice so live polls stop
      // auto-following the current day and keep this selection instead.
      chips.dataset.userSelected = 'true';
      const day = btn.dataset.day!;
      for (const c of chips.querySelectorAll('button.chip')) {
        const on = c === btn;
        c.classList.toggle('active', on);
        c.setAttribute('aria-pressed', on ? 'true' : 'false');
      }
      const { popularByDay, todayDay, nowHour, capacity, heightMax, trend } = popData();
      if (popularByDay?.[day]) {
        const isToday = day === todayDay;
        bars.innerHTML = renderBars(
          popularByDay[day],
          isToday ? trend : null,
          isToday ? nowHour : null,
          capacity,
          heightMax,
        );
      }
    });
  }
</script>

<style>
  .chart-card {
    padding: clamp(16px, 2.4vw, 22px);
  }
  .pop-head {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 8px;
    flex-wrap: wrap;
  }
  .chips {
    display: flex;
    gap: 4px;
    flex-wrap: wrap;
  }
  .chip {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 11px;
    font-weight: 600;
    padding: 5px 8px;
    border-radius: 8px;
    cursor: pointer;
    border: 1px solid var(--border);
    background: transparent;
    color: var(--muted);
    transition: background 0.15s ease, color 0.15s ease, border-color 0.15s ease;
  }
  .chip:hover {
    border-color: var(--muted);
  }
  .chip.active {
    border-color: var(--text);
    background: var(--text);
    color: var(--card);
  }

  .bars {
    margin-top: 14px;
  }
  .ticks {
    display: flex;
    justify-content: space-between;
    margin-top: 6px;
    font-size: 10.5px;
    color: var(--muted);
  }
  .pop-caption {
    margin-top: 10px;
    font-size: 12px;
    color: var(--muted);
  }
</style>
