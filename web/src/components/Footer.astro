---
interface Props {
  secs: number;
}
const { secs } = Astro.props;
---

<footer class="ft">
  
  <span>Refreshes ~every minute · updated <span class="sk-live" id="secs-ago-foot">{secs}</span>s ago</span>
  <span class="cam-note">
    <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="var(--muted)" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round" style="flex-shrink: 0;"><path d="M3 8.5A2 2 0 0 1 5 6.5h9.5a2 2 0 0 1 2 2v1.6l3-2v8.8l-3-2v1.6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path></svg>
   Counted from the City of Kingston's <a class="pier-link" href="https://www.cityofkingston.ca/news-and-notices/webcams/" target="_blank" rel="noopener">public pier webcams</a> 
  </span>
</footer>

<style>
  .ft {
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
    gap: 8px 18px;
    align-items: center;
    padding: 2px 4px 4px;
    font-size: 12px;
    color: var(--muted);
  }
  .cam-note {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    flex-wrap: wrap;
  }
  .pier-link {
    color: inherit;
    text-decoration: underline;
  }
  .pier-link:hover {
    color: var(--fg, inherit);
  }
</style>
