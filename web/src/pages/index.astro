---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import HeroCard from '../components/HeroCard.astro';
import WeatherCard from '../components/WeatherCard.astro';
import PopularTimes from '../components/PopularTimes.astro';
import MethodCard from '../components/MethodCard.astro';
import Footer from '../components/Footer.astro';
import { levelForCount, loHi } from '../lib/busyness';
import { initialNow } from '../lib/api';
import { sceneTime, busiestCaption } from '../lib/format';

// First paint renders synchronously from the synthetic mock (a realistic
// placeholder for a static build); the client immediately fetches the live /now
// and repaints via applyNow(). See the island script below.
const now = initialNow();
const updated = new Date(now.lastUpdated);

const idx = levelForCount(now.total, now.capacity);
const { lo, hi } = loHi(now.total);
const secs = Math.max(0, Math.round((Date.now() - updated.getTime()) / 1000));

const scene = sceneTime(now.lastUpdated);
const timestamp = scene.timestamp;
const todayDay = scene.todayDay;
const popularCaption = busiestCaption(now.popularByDay);
---

<Layout>
  <main class="page" data-feed="live" data-updated={now.lastUpdated}>
    <!-- Mask the placeholder (mock) values with a loading skeleton from the very
         first paint, before the live /now fetch resolves. Runs inline during
         parse so there's no flash of the baked-in numbers. Without JS the
         attribute is never set and the values render normally. -->
    <script is:inline>document.currentScript.closest('.page').dataset.state = 'loading';</script>
    <Header secs={secs} />

    <div class="bento">
      <HeroCard
        total={now.total}
        lo={lo}
        hi={hi}
        levelIdx={idx}
        timestamp={timestamp}
        comparePct={now.comparePct}
      />
     

      

      <div class="charts-row">
        <PopularTimes
          popularByDay={now.popularByDay}
          selectedDay={todayDay}
          todayDay={todayDay}
          nowHour={now.nowHour}
          capacity={now.capacity}
          trend={now.trend}
          caption={popularCaption}
        />
      </div>
      <WeatherCard weather={now.weather} />
      <MethodCard />
    </div>

    <Footer secs={secs} />
  </main>
</Layout>

<script>
  // Theme toggle: explicit choice wins over the OS preference and persists.
  const toggle = document.getElementById('theme-toggle');
  toggle?.addEventListener('click', () => {
    const root = document.documentElement;
    const current =
      root.getAttribute('data-theme') ??
      (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
    const next = current === 'dark' ? 'light' : 'dark';
    root.setAttribute('data-theme', next);
    try {
      localStorage.setItem('kp-theme', next);
    } catch (_) {}
  });

  // Freshness ticker: derive "updated Ns ago" from the reading timestamp.
  const page = document.querySelector('.page') as HTMLElement | null;
  const secsEls = [document.getElementById('secs-ago'), document.getElementById('secs-ago-foot')];
  function tick() {
    const iso = page?.dataset.updated;
    if (!iso) return;
    const s = Math.max(0, Math.round((Date.now() - new Date(iso).getTime()) / 1000));
    for (const el of secsEls) if (el) el.textContent = String(s);
  }
  tick();
  setInterval(tick, 1000);

  // Live data: fetch /now immediately, then poll ~every 60s. applyNow() repaints
  // the hero, weather, charts and status from the payload. On failure keep the
  // last-good view and flip to the stale state (never blank the page).
  import { fetchNow, STALE_AFTER_MS } from '../lib/api';
  import { applyNow } from '../lib/live';
  async function poll() {
    const data = await fetchNow();
    if (!data) {
      // If we've never rendered real data, drop the shimmer to a static "no
      // data" placeholder (never reveal the mock numbers). Once we've had a
      // successful reading, keep showing it as the last-known value instead.
      if (page && page.dataset.state !== 'live') page.dataset.state = 'error';
      page?.setAttribute('data-feed', 'stale');
      return;
    }
    applyNow(data);
    if (page) {
      page.dataset.updated = data.lastUpdated;
      page.dataset.state = 'live'; // reveal the real values, clear the skeleton
    }
    const age = Date.now() - new Date(data.lastUpdated).getTime();
    page?.setAttribute('data-feed', age > STALE_AFTER_MS ? 'stale' : 'live');
    tick();
  }
  poll();
  setInterval(poll, 60_000);
</script>
