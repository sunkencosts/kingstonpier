---
interface Props {
  secs: number;
}
const { secs } = Astro.props;
---

<header class="hdr">
  <div class="brand">
    <div class="logo" aria-hidden="true">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#3a2500" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M12 3.2v17.6M8.6 6.4h6.8M5 12.2H2.4M21.6 12.2H19M6 12.2a6 6 0 0 0 12 0"></path>
      </svg>
    </div>
    <div class="wordmark">
      <span class="name">Kingston&nbsp;Pier</span>
      <span class="sub">Breakwater Park · Kingston, ON</span>
    </div>
  </div>

  <div class="hdr-right">
    <!-- Live -->
    <div class="pill status status-live" role="status">
      <span class="dot-wrap">
        <span class="dot"></span>
        <span class="dot live-ping"></span>
      </span>
      <span class="status-txt">Live · updated <span id="secs-ago">{secs}</span>s ago</span>
    </div>
    <!-- Stale (shown when [data-feed="stale"]) -->
    <div class="pill status status-stale" role="status">
      <span class="dot-stale"></span>
      <span class="status-txt">Feed unavailable · <span id="stale-ago">last seen 6m ago</span></span>
    </div>

    <button id="theme-toggle" class="pill theme-btn" type="button" aria-label="Toggle dark mode" title="Toggle theme">
      <svg class="ico-sun" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round">
        <circle cx="12" cy="12" r="4.2"></circle>
        <path d="M12 2.5v2.4M12 19.1v2.4M4.6 4.6l1.7 1.7M17.7 17.7l1.7 1.7M2.5 12h2.4M19.1 12h2.4M4.6 19.4l1.7-1.7M17.7 6.3l1.7-1.7"></path>
      </svg>
      <svg class="ico-moon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round">
        <path d="M21 12.8A9 9 0 1 1 11.2 3a7 7 0 0 0 9.8 9.8z"></path>
      </svg>
    </button>
  </div>
</header>

<style>
  .hdr {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 12px;
    flex-wrap: wrap;
  }
  .brand {
    display: flex;
    align-items: center;
    gap: 11px;
  }
  .logo {
    width: 36px;
    height: 36px;
    border-radius: 11px;
    background: var(--accent);
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 3px 8px -2px rgba(120, 80, 0, 0.35);
  }
  .wordmark {
    display: flex;
    flex-direction: column;
    line-height: 1.15;
  }
  .name {
    font-family: 'Space Grotesk', sans-serif;
    font-weight: 700;
    font-size: 17px;
    letter-spacing: -0.01em;
    color: var(--heading);
  }
  .sub {
    font-size: 11.5px;
    color: var(--muted);
  }

  .hdr-right {
    display: flex;
    align-items: center;
    gap: 8px;
  }
  .pill {
    display: flex;
    align-items: center;
    gap: 9px;
    padding: 8px 13px;
    border-radius: 999px;
    background: var(--card);
    border: 1px solid var(--border);
    font-size: 12px;
    font-weight: 600;
    color: var(--text);
  }
  .status-txt {
    white-space: nowrap;
  }

  .dot-wrap {
    position: relative;
    width: 8px;
    height: 8px;
    display: inline-block;
  }
  .dot,
  .live-ping {
    position: absolute;
    inset: 0;
    border-radius: 50%;
    background: #33a88b;
  }
  .live-ping {
    animation: pierPulse 2.4s ease-out infinite;
  }

  .status-stale {
    background: color-mix(in srgb, #de5240 15%, var(--card));
    border-color: color-mix(in srgb, #de5240 40%, transparent);
  }
  .dot-stale {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: #de5240;
  }

  /* Toggle which status pill is visible based on the feed state. */
  :global([data-feed='stale']) .status-live {
    display: none;
  }
  :global(:not([data-feed='stale'])) .status-stale {
    display: none;
  }

  .theme-btn {
    cursor: pointer;
    color: var(--muted);
    padding: 8px;
  }
  .theme-btn:hover {
    color: var(--text);
  }
  .ico-moon {
    display: none;
  }
  :global([data-theme='dark']) .ico-sun {
    display: none;
  }
  :global([data-theme='dark']) .ico-moon {
    display: inline;
  }
</style>
